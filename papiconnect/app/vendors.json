{
  "sony_bravia_tv": {
    "name": "Sony",
    "version": "v1.0 (Bravia Simple IP)",
    "description": "Sony Bravia TVs using Pre-Shared Key (PSK) authentication.",
    "type": "tv",
    "get_apps_request": {
      "method": "POST",
      "url": "http://{device_ip}/sony/appControl",
      "headers": {
        "X-Auth-PSK": "0000",
        "Content-Type": "application/json"
      },
      "payload": {
        "method": "getApplicationList",
        "version": "1.0",
        "id": 1,
        "params": []
      }
    },
    "api_calls": {
      "Get Application List": {
        "protocol": "HTTP",
        "method": "POST",
        "port": 80,
        "path": "/sony/appControl",
        "headers": {
          "X-Auth-PSK": "0000",
          "Content-Type": "application/json"
        },
        "payload": {
          "method": "getApplicationList",
          "version": "1.0",
          "id": 1,
          "params": []
        }
      },
      "Launch Application": {
        "protocol": "HTTP",
        "method": "POST",
        "port": 80,
        "path": "/sony/appControl",
        "headers": {
          "X-Auth-PSK": "0000",
          "Content-Type": "application/json"
        },
        "payload": {
          "method": "setActiveApp",
          "version": "1.0",
          "id": 1,
          "params": [{"uri": "App URI (e.g. com.sony.dtv.com.netflix.ninja...)"}]
        }
      }
    },
    "launch_action_template": {
      "protocol": "HTTP",
      "method": "POST",
      "port": 80,
      "path": "/sony/appControl",
      "headers": {
        "X-Auth-PSK": "0000",
        "Content-Type": "application/json"
      },
      "payload": {
        "method": "setActiveApp",
        "version": "1.0",
        "id": 1,
        "params": [{"uri": "{app_uri}"}]
      }
    }
  },
  "denon_amplifier": {
    "name": "Denon",
    "version": "v1.0 (Telnet TCP)",
    "description": "Denon and Marantz AV Receivers controlled via raw TCP Telnet protocol commands.",
    "type": "amplifier",
    "get_apps_request": {
      "method": "STATIC",
      "apps": ["Spotify"]
    },
    "api_calls": {
      "Get Application List": {
        "protocol": "STATIC",
        "apps": ["Spotify"]
      },
      "Power On & Select Spotify/NET Input": {
        "protocol": "TCP",
        "port": 23,
        "payload": "SINET\r"
      },
      "Power Off (Standby)": {
        "protocol": "TCP",
        "port": 23,
        "payload": "PWSTANDBY\r"
      }
    }
  },
