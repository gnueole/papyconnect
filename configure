#!/usr/bin/env python3
import sys

def get_input(prompt, default):
    try:
        val = input(f"{prompt} [{default}]: ").strip()
        return val if val else default
    except KeyboardInterrupt:
        print("\nConfiguration aborted by user.")
        sys.exit(0)

def validate_port(port_str):
    try:
        port = int(port_str)
        if 1 <= port <= 65535:
            return port
    except ValueError:
        pass
    return None

def main():
    print("=========================================")
    print(" PapyConnect — Configuration Wizard")
    print("=========================================\n")
    
    # 1. Ask Hostname
    gronas_ip = get_input("Gronas IP or Hostname", "gronas")
    
    # 2. Ask PapyConnect Port
    papy_port = None
    while not papy_port:
        papy_port_raw = get_input("Port for PapyConnect", "8000")
        papy_port = validate_port(papy_port_raw)
        if not papy_port:
            print("ERROR: Invalid port. Please enter a number between 1 and 65535.")
            
    # 3. Ask n8n Port
    n8n_port = None
    while not n8n_port:
        n8n_port_raw = get_input("Port for n8n", "5678")
        n8n_port = validate_port(n8n_port_raw)
        if not n8n_port:
            print("ERROR: Invalid port. Please enter a number between 1 and 65535.")
            
    # 4. Ask Storage Type
    storage_type = None
    while not storage_type:
        st_raw = get_input("Storage Type (synology / raspberry)", "synology").lower()
        if st_raw in ["synology", "raspberry"]:
            storage_type = st_raw
        else:
            print("ERROR: Invalid choice. Please enter 'synology' or 'raspberry'.")
            
    # 5. Ask Storage User
    default_user = "root" if storage_type == "synology" else "pi"
    storage_user = get_input("User login for storage", default_user)
    while not storage_user:
        print("ERROR: Storage user login cannot be empty.")
        storage_user = get_input("User login for storage", default_user)

    # 6. Generate .env file
    env_content = f"""# Configurations generated by ./configure
GRONAS_IP={gronas_ip}
PAPYCONNECT_PORT={papy_port}
N8N_PORT={n8n_port}
STORAGE_TYPE={storage_type}
STORAGE_USER={storage_user}
"""

    try:
        with open(".env", "w", encoding="utf-8") as f:
            f.write(env_content)
        print("\n=========================================")
        print(" Configuration generated successfully!")
        print("=========================================")
        print("The '.env' file has been created at the project root.")
        print("\nTo compile and deploy the stack:")
        print("  docker compose -f papiconnect/docker-compose.yml up -d")
        print("=========================================\n")
    except Exception as e:
        print(f"\nERROR writing .env file: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
