  "philips_wiz": {
    "name": "Philips WiZ",
    "version": "v1.0 (WiZ UDP)",
    "description": "Philips WiZ WiFi smart lights controlled via local UDP JSON packets.",
    "type": "lighting",
    "get_apps_request": {
      "method": "STATIC",
      "apps": ["Toggle Light", "Daylight Scene", "Night Light Scene"]
    },
    "api_calls": {
      "Get Application List": {
        "protocol": "STATIC",
        "apps": ["Toggle Light", "Daylight Scene", "Night Light Scene"]
      },
      "Power On": {
        "protocol": "UDP",
        "port": 38899,
        "payload": "{\n          \"method\": \"setPilot\",\n          \"params\": {\n            \"state\": true\n          }\n        }"
      },
      "Power Off": {
        "protocol": "UDP",
        "port": 38899,
        "payload": "{\n          \"method\": \"setPilot\",\n          \"params\": {\n            \"state\": false\n          }\n        }"
      },
      "Set Color Temp": {
        "protocol": "UDP",
        "port": 38899,
        "payload": "{\n          \"method\": \"setPilot\",\n          \"params\": {\n            \"state\": true,\n            \"temp\": 4000\n          }\n        }"
      }
    }
  },
