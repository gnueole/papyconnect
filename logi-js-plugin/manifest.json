{
  "manifest_version": 2,
  "id": "me.eole.papyconnect",
  "name": "PapyConnect Console",
  "version": "1.0.0",
  "description": "Executes virtual actions via the n8n gateway",
  "author": "Éole Lab",
  "background": {
    "scripts": ["plugin.js"]
  },
  "actions": [
    {
      "id": "papyconnect_btn_1",
      "name": "PapyConnect Button 1",
      "type": "custom"
    },
    {
      "id": "papyconnect_btn_2",
      "name": "PapyConnect Button 2",
      "type": "custom"
    },
    {
      "id": "papyconnect_btn_3",
      "name": "PapyConnect Button 3",
      "type": "custom"
    },
    {
      "id": "papyconnect_btn_4",
      "name": "PapyConnect Button 4",
      "type": "custom"
    },
    {
      "id": "papyconnect_btn_5",
      "name": "PapyConnect Button 5",
      "type": "custom"
    },
    {
      "id": "papyconnect_btn_6",
      "name": "PapyConnect Button 6",
      "type": "custom"
    },
    {
      "id": "open_wizard",
      "name": "Open Configuration Wizard",
      "type": "custom"
    }
  ],
  "settings": {
    "gronas_n8n_url": {
      "type": "string",
      "label": "n8n Gateway URL",
      "default": "http://gronas:5678",
      "description": "The root URL of your local n8n instance (Gronas)."
    }
  }
}
