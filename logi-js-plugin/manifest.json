{
  "manifest_version": 2,
  "id": "me.eole.papyconnect",
  "name": "PapyConnect Console",
  "version": "1.0.0",
  "description": "Exécute des actions virtuelles via la passerelle n8n",
  "author": "Éole Lab",
  "background": {
    "scripts": ["plugin.js"]
  },
  "actions": [
    {
      "id": "papyconnect_btn_1",
      "name": "Bouton PapyConnect 1",
      "type": "custom"
    },
    {
      "id": "papyconnect_btn_2",
      "name": "Bouton PapyConnect 2",
      "type": "custom"
    },
    {
      "id": "papyconnect_btn_3",
      "name": "Bouton PapyConnect 3",
      "type": "custom"
    },
    {
      "id": "papyconnect_btn_4",
      "name": "Bouton PapyConnect 4",
      "type": "custom"
    },
    {
      "id": "papyconnect_btn_5",
      "name": "Bouton PapyConnect 5",
      "type": "custom"
    },
    {
      "id": "papyconnect_btn_6",
      "name": "Bouton PapyConnect 6",
      "type": "custom"
    },
    {
      "id": "open_wizard",
      "name": "Ouvrir le Wizard de Configuration",
      "type": "custom"
    }
  ],
  "settings": {
    "gronas_n8n_url": {
      "type": "string",
      "label": "URL Gateway n8n",
      "default": "http://gronas:5678",
      "description": "L'URL racine de votre instance n8n locale (Gronas)."
    }
  }
}
